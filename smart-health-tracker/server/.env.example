# Environment Variables Example

# Copy this file to .env and update with your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-health-tracker

# OR MongoDB Atlas (Cloud - recommended for production)
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/smart-health-tracker?retryWrites=true&w=majority

# Authentication
JWT_SECRET=change_this_to_a_very_long_random_string_for_production_12345678901234567890
JWT_EXPIRY=7d

# CORS & Frontend
CLIENT_URL=http://localhost:3000

# IoT Configuration
IOT_API_PORT=5001

# Logging (Optional)
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email Notifications (Future)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=noreply@healthtracker.com
# SMTP_PASSWORD=your_email_password

# AWS/Cloud Services (Optional)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=us-east-1

# Database Backup (Optional)
# BACKUP_LOCATION=/backups
# BACKUP_SCHEDULE=0 2 * * *  (Every day at 2 AM)
